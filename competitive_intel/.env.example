# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...

# changedetection.io — get API key from Settings → API in your cd.io dashboard
# Base URL: your hosted account URL (no trailing slash), e.g.
#   https://lewisdyson.changedetection.io
CHANGEDETECTION_API_KEY=
CHANGEDETECTION_BASE_URL=

# ── Notion — set after running setup_notion.py ────────────────────────────────
NOTION_PARENT_PAGE_ID=your_notion_page_id_here
NOTION_CHANGES_DB_ID=

# ── MS Teams — add webhook URLs once channels are created ─────────────────────
TEAMS_GENERAL_WEBHOOK=
TEAMS_WEBHOOK_EQUISOFT=
TEAMS_WEBHOOK_CLOVEN=
TEAMS_WEBHOOK_HUBSPOT=
TEAMS_WEBHOOK_LAYLAH=
TEAMS_WEBHOOK_SALESFORCE=
TEAMS_WEBHOOK_WEALTHBOX=
TEAMS_WEBHOOK_MONDAY=
TEAMS_WEBHOOK_ZOHO=
TEAMS_WEBHOOK_ONEVEST=
TEAMS_WEBHOOK_PIPEDRIVE=
TEAMS_WEBHOOK_ADVORA=

# ── Email / Newsletter (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
SMTP_FROM=competitive-intel@maximizer.com
NEWSLETTER_RECIPIENTS=lewisdyson@maximizer.com
